<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>근무 관리</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>work_manager_mobile</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>

    <!-- Permissions ============================================== -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>출퇴근 위치 인증을 위해 사용 중에만 위치 정보를 사용합니다.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>지정된 본사/재택 위치 진입·이탈 시 자동 출퇴근을 위해 백그라운드 위치를 사용합니다.</string>
    <key>NSCameraUsageDescription</key>
    <string>프로필 사진 촬영을 위해 카메라를 사용합니다.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>프로필 사진 선택을 위해 사진에 접근합니다.</string>
    <key>NSUserNotificationsUsageDescription</key>
    <string>출퇴근, 결재, 알림을 받기 위해 사용합니다.</string>

    <!-- Background modes =========================================
         WARNING: `location` triggers extra Apple App Review scrutiny.
         Reviewers will reject builds that request always-on location
         without (a) a clear in-app explainer screen referenced from
         the App Store description, (b) `NSLocationAlways...` purpose
         string that names the geofence feature, and (c) graceful
         degradation when permission is denied. See
         lib/geofence/geofence_service.dart and docs/specs/feature-spec.md §3.4.
    -->
    <key>UIBackgroundModes</key>
    <array>
        <string>fetch</string>
        <string>location</string>
        <string>remote-notification</string>
    </array>

    <!-- Allow loading the dev SPA over http for the iOS simulator only.
         Production scheme should toggle NSAllowsArbitraryLoads off and use
         per-domain exceptions. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoadsInWebContent</key>
        <true/>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>

    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
    <string>Main</string>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>
    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>
</dict>
</plist>
